PORT=3001
CLIENT_ORIGIN=http://localhost:3000

# Optional comma-separated allowlist for production frontend URLs.
CLIENT_URL=

# Initial employee login seed. On first run, the backend stores this account in the database.
EMPLOYEE_USERNAME=librarian
EMPLOYEE_PASSWORD=change_me
EMPLOYEE_NAME=GCC Library Staff
EMPLOYEE_TITLE=Library Administrator
EMPLOYEE_EMAIL=
EMPLOYEE_PHONE=
EMPLOYEE_INFO=

# Optional JSON array for multiple employee logins.
# Example: [{"username":"librarian","password":"change_me","name":"Library Staff"}]
EMPLOYEE_ACCOUNTS_JSON=

# Optional. If omitted, the server derives a signing secret from the employee credentials.
AUTH_SECRET=
AUTH_TOKEN_TTL_HOURS=12

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=library_attendance
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA_PATH=
DB_CONNECTION_LIMIT=10

# Use `local` for local development and `cloudinary` on Vercel deployments.
FILE_STORAGE=local

# Optional for cloud image storage in production
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=library-app/profiles

# Optional TiDB Cloud aliases. If present, the backend can use these instead of DB_* variables.
TIDB_HOST=your_tidb_host
TIDB_PORT=4000
TIDB_USER=your_tidb_user
TIDB_PASSWORD=your_tidb_password
TIDB_DATABASE=library_attendance
TIDB_ENABLE_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
